[Unit]
Description=IPDR MikroTik /ppp/secret sync (LEA enrichment cache)
After=network-online.target postgresql.service
Wants=network-online.target

[Service]
Type=oneshot
User=ipdr
EnvironmentFile=/opt/ipdr/.env
Environment=IPDR_ENV=/opt/ipdr/.env
ExecStart=/opt/ipdr/venv/bin/python /opt/ipdr/scripts/mikrotik_secrets_sync.py
# Don't let a slow/unreachable router hang forever.
TimeoutStartSec=120
