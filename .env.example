# IPDR — example environment. Copy to .env and fill in real values.
# NEVER commit the real .env.

# PostgreSQL connection
DATABASE_URL=postgresql://ipdr_user:CHANGE_ME@127.0.0.1:5432/ipdr

# Flask session secret (generate: python -c "import secrets;print(secrets.token_hex(32))")
FLASK_SECRET=CHANGE_ME_RANDOM_HEX

# Fernet key for encrypting stored NAS API passwords
# Generate: python -c "from cryptography.fernet import Fernet;print(Fernet.generate_key().decode())"
MT_FERNET_KEY=CHANGE_ME_FERNET_KEY

# Bearer token for the LEA API endpoint
# Generate: python -c "import secrets;print(secrets.token_urlsafe(32))"
LEA_API_TOKEN=CHANGE_ME_API_TOKEN

# Optional: data retention window (days) — set to your regulatory obligation
MT_RETENTION_DAYS=90
